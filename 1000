<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Seekmed — Pedido 1000 / teste</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
  :root{--bg:#f4f6f9;--surface:#ffffff;--surface2:#f0f3f7;--border:#e2e7ef;--text:#1a2236;--text2:#5a6b85;--accent:#0057b7;--accent-light:#e8f0fb;--accent2:#00a3a3;--success:#00875a;--success-light:#e3f5ee;--warning:#e07b00;--warning-light:#fff4e0;--danger:#c0392b;--radius:14px;--shadow:0 2px 12px rgba(26,34,54,.07);--shadow-lg:0 8px 32px rgba(26,34,54,.10);}
  *{box-sizing:border-box;margin:0;padding:0;}
  body{font-family:'DM Sans',sans-serif;background:var(--bg);color:var(--text);min-height:100vh;font-size:15px;}
  header{background:#fff;border-bottom:1px solid var(--border);padding:0 40px;height:64px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:100;}
  .logo{display:flex;align-items:center;gap:12px;}
  .logo-icon{width:36px;height:36px;background:var(--accent);border-radius:10px;display:flex;align-items:center;justify-content:center;}
  .logo-icon svg{width:20px;height:20px;}
  .logo-text{font-size:18px;font-weight:600;letter-spacing:-.3px;}
  .logo-text span{color:var(--accent);}
  .badge-status{padding:5px 14px;border-radius:20px;font-size:13px;font-weight:500;display:flex;align-items:center;gap:6px;}
  .badge-status.em-preparacao{background:var(--warning-light);color:var(--warning);}
  .badge-status.pronto{background:var(--success-light);color:var(--success);}
  .badge-status.enviado{background:var(--accent-light);color:var(--accent);}
  .dot{width:7px;height:7px;border-radius:50%;background:currentColor;animation:pulse 1.8s infinite;}
  @keyframes pulse{0%,100%{opacity:1}50%{opacity:.4}}
  .container{max-width:1100px;margin:0 auto;padding:36px 24px 60px;}
  .grid{display:grid;gap:24px;}
  .grid-2{grid-template-columns:1fr 1fr;}
  @media(max-width:760px){.grid-2{grid-template-columns:1fr}header{padding:0 20px}.container{padding:24px 16px 60px}}
  .card{background:#fff;border-radius:var(--radius);border:1px solid var(--border);box-shadow:var(--shadow);overflow:hidden;}
  .card-header{padding:20px 24px 16px;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:10px;}
  .card-header-icon{width:32px;height:32px;border-radius:8px;display:flex;align-items:center;justify-content:center;flex-shrink:0;}
  .card-header-icon.blue{background:var(--accent-light);color:var(--accent);}
  .card-header-icon.teal{background:#e0f7f7;color:var(--accent2);}
  .card-header-icon.orange{background:var(--warning-light);color:var(--warning);}
  .card-header-icon svg{width:16px;height:16px;}
  .card-title{font-size:14px;font-weight:600;letter-spacing:.4px;text-transform:uppercase;color:var(--text2);}
  .card-body{padding:24px;}
  .order-meta{display:flex;align-items:flex-start;justify-content:space-between;flex-wrap:wrap;gap:16px;margin-bottom:28px;}
  .order-number{font-size:28px;font-weight:600;letter-spacing:-.5px;}
  .order-sub{font-size:13px;color:var(--text2);margin-top:4px;}
  .order-sub strong{color:var(--text);}
  .steps{display:flex;align-items:center;margin:8px 0 4px;}
  .step{display:flex;flex-direction:column;align-items:center;flex:1;}
  .step-circle{width:32px;height:32px;border-radius:50%;border:2px solid var(--border);background:#fff;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:600;color:var(--text2);z-index:1;transition:all .3s;}
  .step.done .step-circle{background:var(--accent);border-color:var(--accent);color:#fff;}
  .step.active .step-circle{border-color:var(--accent);color:var(--accent);box-shadow:0 0 0 4px var(--accent-light);}
  .step-label{font-size:11px;color:var(--text2);margin-top:8px;text-align:center;white-space:nowrap;}
  .step.done .step-label,.step.active .step-label{color:var(--accent);font-weight:500;}
  .step-line{flex:1;height:2px;background:var(--border);margin-bottom:20px;position:relative;overflow:hidden;}
  .step-line.done::after{content:'';position:absolute;inset:0;background:var(--accent);}
  .product-list{display:flex;flex-direction:column;gap:16px;}
  .product-item{display:flex;align-items:center;gap:16px;}
  .product-num{font-family:'DM Mono',monospace;font-size:12px;color:var(--text2);width:20px;flex-shrink:0;text-align:right;}
  .product-info{flex:1;min-width:0;}
  .product-name{font-size:14px;font-weight:500;margin-bottom:6px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
  .product-desc{font-size:12px;color:var(--text2);margin-bottom:8px;}
  .bar-wrap{height:6px;background:var(--surface2);border-radius:4px;overflow:hidden;}
  .bar-fill{height:100%;border-radius:4px;background:var(--accent);transition:width .6s cubic-bezier(.4,0,.2,1);}
  .bar-fill.full{background:var(--success);}
  .bar-fill.low{background:var(--danger);}
  .bar-fill.mid{background:var(--warning);}
  .product-qty{font-family:'DM Mono',monospace;font-size:13px;font-weight:500;width:70px;text-align:right;flex-shrink:0;}
  .product-divider{height:1px;background:var(--border);}
  .nf-prefixo{background:var(--surface2);border:1px solid var(--border);border-radius:10px;padding:14px 16px;font-size:13px;color:var(--text2);line-height:1.7;margin-bottom:16px;}
  .nf-prefixo strong{color:var(--text);}
  .nf-label{font-size:12px;font-weight:600;text-transform:uppercase;letter-spacing:.5px;color:var(--text2);margin-bottom:8px;}
  .nf-textarea{width:100%;border:1.5px solid var(--border);border-radius:10px;padding:12px 14px;font-family:inherit;font-size:14px;color:var(--text);background:#fff;resize:vertical;min-height:90px;transition:border-color .2s,box-shadow .2s;outline:none;}
  .nf-textarea:focus{border-color:var(--accent);box-shadow:0 0 0 3px var(--accent-light);}
  .nf-textarea::placeholder{color:#b0bac8;}
  .nf-send-btn{margin-top:12px;background:var(--accent);color:#fff;border:none;border-radius:10px;padding:11px 22px;font-family:inherit;font-size:14px;font-weight:500;cursor:pointer;display:flex;align-items:center;gap:8px;transition:background .2s,transform .1s;}
  .nf-send-btn:hover{background:#0046a0;}
  .nf-sent-msg{display:none;align-items:center;gap:8px;margin-top:10px;color:var(--success);font-size:13px;font-weight:500;}
  .transport-info{display:flex;align-items:center;gap:16px;margin-bottom:20px;flex-wrap:wrap;}
  .transport-avatar{width:44px;height:44px;background:var(--accent-light);border-radius:50%;display:flex;align-items:center;justify-content:center;color:var(--accent);font-weight:700;font-size:16px;flex-shrink:0;}
  .transport-name{font-weight:600;font-size:15px;}
  .transport-vol{font-size:13px;color:var(--text2);margin-top:2px;}
  .transport-pct-wrap{margin-top:8px;}
  .transport-pct-header{display:flex;justify-content:space-between;font-size:13px;margin-bottom:8px;}
  .transport-pct-header span:last-child{font-family:'DM Mono',monospace;font-weight:500;color:var(--accent);}
  .transport-bar{height:10px;background:var(--surface2);border-radius:8px;overflow:hidden;}
  .transport-bar-fill{height:100%;background:linear-gradient(90deg,var(--accent),var(--accent2));border-radius:8px;transition:width .8s cubic-bezier(.4,0,.2,1);}
  .transport-stages{display:flex;justify-content:space-between;margin-top:6px;font-size:11px;color:var(--text2);}
  .tag{display:inline-block;padding:3px 10px;border-radius:20px;font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:.4px;}
  .tag.blue{background:var(--accent-light);color:var(--accent);}
</style>
</head>
<body>
<header>
  <div class="logo">
    <div class="logo-icon">
      <svg viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
    </div>
    <span class="logo-text">Seek<span>med</span></span>
  </div>
  <div>
    <span id="headerStatus" class="badge-status em-preparacao">
      <span class="dot"></span><span id="headerStatusText">Em Preparação</span>
    </span>
  </div>
</header>
<div class="container">
  <div class="order-meta">
    <div>
      <div class="order-number">Pedido #1000 / teste</div>
      <div class="order-sub">Cliente: <strong>FABRICIO</strong> &nbsp;·&nbsp; Data: <strong>01/05/2026 / Entrega: 10/05/2026</strong></div>
    </div>
  </div>
  <div class="card" style="margin-bottom:24px;">
    <div class="card-body" style="padding:28px 32px 24px;">
      <div class="steps" id="stepsContainer">
        <div class="step" id="step1"><div class="step-circle">1</div><div class="step-label">Pedido Recebido</div></div>
        <div class="step-line" id="line1"></div>
        <div class="step" id="step2"><div class="step-circle">2</div><div class="step-label">Em Preparação</div></div>
        <div class="step-line" id="line2"></div>
        <div class="step" id="step3"><div class="step-circle">3</div><div class="step-label">Pronto para Envio</div></div>
        <div class="step-line" id="line3"></div>
        <div class="step" id="step4"><div class="step-circle">4</div><div class="step-label">Em Trânsito</div></div>
        <div class="step-line" id="line4"></div>
        <div class="step" id="step5"><div class="step-circle">5</div><div class="step-label">Entregue</div></div>
      </div>
    </div>
  </div>
  <div class="grid grid-2">
    <div class="card">
      <div class="card-header">
        <div class="card-header-icon blue"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg></div>
        <div class="card-title">Produtos</div>
      </div>
      <div class="card-body"><div class="product-list" id="productList"></div></div>
    </div>
    <div class="grid" style="gap:24px;">
      <div class="card">
        <div class="card-header">
          <div class="card-header-icon orange"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg></div>
          <div class="card-title">Observações da Nota Fiscal</div>
        </div>
        <div class="card-body">
          <div class="nf-prefixo" id="nfPrefixo"><strong>Dados pré-definidos:</strong><br></div>
          <div class="nf-label">Adicionar observação complementar</div>
          <textarea class="nf-textarea" id="nfObs" placeholder="Digite aqui qualquer observação adicional…"></textarea>
          <button class="nf-send-btn" onclick="sendNfObs()">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
            Enviar Observação
          </button>
          <div class="nf-sent-msg" id="nfSentMsg">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="20 6 9 17 4 12"/></svg>
            Observação enviada com sucesso!
          </div>
        </div>
      </div>
      <div class="card">
        <div class="card-header">
          <div class="card-header-icon teal"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg></div>
          <div class="card-title">Status de Transporte</div>
        </div>
        <div class="card-body">
          <div class="transport-info">
            <div class="transport-avatar" id="transportAvatar">TR</div>
            <div>
              <div class="transport-name">—</div>
              <div class="transport-vol"><span>2 volumes</span> &nbsp;·&nbsp; <span class="tag blue" id="transportTag">—</span></div>
            </div>
          </div>
          <div class="transport-pct-wrap">
            <div class="transport-pct-header"><span>Progresso de entrega</span><span id="transportPctLabel">0%</span></div>
            <div class="transport-bar"><div class="transport-bar-fill" id="transportBar" style="width:0%"></div></div>
            <div class="transport-stages"><span>Coletado</span><span>Em rota</span><span>Chegando</span><span>Entregue</span></div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
<script>
const statusMap={1:{label:"Pedido Recebido",cls:"em-preparacao"},2:{label:"Em Preparação",cls:"em-preparacao"},3:{label:"Pronto para Envio",cls:"pronto"},4:{label:"Em Trânsito",cls:"enviado"},5:{label:"Entregue",cls:"pronto"}};
const s=2;
function renderSteps(){for(let i=1;i<=5;i++){const el=document.getElementById("step"+i);el.className="step";if(i<s)el.classList.add("done");else if(i===s)el.classList.add("active");const c=el.querySelector(".step-circle");c.innerHTML=i<s?'<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="20 6 9 17 4 12"/></svg>':i;if(i<5){const l=document.getElementById("line"+i);l.className="step-line"+(i<s?" done":"");}};const b=document.getElementById("headerStatus");const info=statusMap[s];b.className="badge-status "+info.cls;b.innerHTML='<span class="dot"></span><span>'+info.label+'</span>';}
const prods=[{"name":"TESTE","desc":"Disponível","qty":"1","pct":80}];
function renderProducts(){const list=document.getElementById("productList");list.innerHTML="";prods.forEach((p,i)=>{const pct=Math.min(100,Math.max(0,p.pct));const bc=pct>=80?"full":pct>=40?"":pct>=20?"mid":"low";list.innerHTML+='<div><div class="product-item"><span class="product-num">'+String(i+1).padStart(2,"0")+'.</span><div class="product-info"><div class="product-name">'+p.name+'</div><div class="product-desc">'+p.desc+'</div><div class="bar-wrap"><div class="bar-fill '+bc+'" style="width:'+pct+'%"></div></div></div><span class="product-qty">'+p.qty+'</span></div>'+(i<prods.length-1?'<div class="product-divider" style="margin:12px 0;"></div>':'')+'</div>';});}
const tPct=0;
const tag=document.getElementById("transportTag");
if(tPct<10)tag.textContent="Aguardando coleta";else if(tPct<50)tag.textContent="Em rota";else if(tPct<90)tag.textContent="Em trânsito";else if(tPct<100)tag.textContent="Chegando";else tag.textContent="Entregue";
function sendNfObs(){const txt=document.getElementById("nfObs").value.trim();if(!txt)return;const btn=document.querySelector(".nf-send-btn");btn.disabled=true;fetch("https://hook.us2.make.com/gc6ktwdilcbq3hi59np0772u0xcq69lg",{method:"POST",headers:{"Content-Type":"application/json"},body:JSON.stringify({pedido:"1000 / teste",cliente:"FABRICIO",observacao:txt,data_envio:new Date().toLocaleString("pt-BR")})}).then(r=>{if(r.ok){btn.style.background="var(--success)";btn.innerHTML='<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="20 6 9 17 4 12"/></svg> Enviado!';document.getElementById("nfSentMsg").style.display="flex";setTimeout(()=>{btn.disabled=false;btn.style.background="";btn.innerHTML='<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg> Enviar Observação';document.getElementById("nfSentMsg").style.display="none";document.getElementById("nfObs").value="";},3500);}else throw new Error();}).catch(()=>{alert("Erro ao conectar. Tente novamente.");btn.disabled=false;});}
renderSteps();renderProducts();
</script>
</body>
</html>
